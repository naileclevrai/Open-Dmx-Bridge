<Application x:Class="OpenDMXBridge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
            <SolidColorBrush x:Key="WarnBgBrush" Color="#FFF4CE"/>
            <SolidColorBrush x:Key="WarnBorderBrush" Color="#F2C94C"/>
            <SolidColorBrush x:Key="WarnTextBrush" Color="#5C4A00"/>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,6"/>
                <Setter Property="MinWidth" Value="90"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style x:Key="SectionGroup" TargetType="GroupBox">
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="Padding" Value="8"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

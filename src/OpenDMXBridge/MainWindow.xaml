<Window x:Class="OpenDMXBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OpenDMXBridge.Controls"
        xmlns:conv="clr-namespace:OpenDMXBridge.Converters"
        xmlns:models="clr-namespace:OpenDMXBridge.Models"
        xmlns:contracts="clr-namespace:OpenDMXBridge.Services.Contracts"
        Title="OpenDMX Bridge"
        Height="860"
        Width="1240"
        MinHeight="680"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="StatusBrushConverter"/>
        <conv:LogLevelToBrushConverter x:Key="LogLevelBrushConverter"/>
        <conv:BridgeToggleTextConverter x:Key="BridgeToggleTextConverter"/>
        <conv:FtdiStateConverter x:Key="OutputStateConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="14,10" Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OpenDMX Bridge" FontSize="18" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleBridgeCommand}"
                        Content="{Binding IsBridgeRunning, Converter={StaticResource BridgeToggleTextConverter}}"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.RowSpan="2">
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Mode" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox SelectedItem="{Binding OperationMode}" Margin="0,0,0,8">
                        <models:BridgeOperationMode>Bridge</models:BridgeOperationMode>
                        <models:BridgeOperationMode>Monitor</models:BridgeOperationMode>
                    </ComboBox>
                    <TextBlock Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="11"
                               Text="Monitor : analyse réseau sans sortie DMX physique."/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Réseau" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Label Content="Carte réseau"/>
                    <ComboBox ItemsSource="{Binding NetworkAdapters}" SelectedItem="{Binding SelectedAdapter}"
                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                    <Button Content="Actualiser" Command="{Binding RefreshAdaptersCommand}" Margin="0,0,0,12"/>
                    <Label Content="Univers Art-Net (Net.SubNet.Universe)"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="8"/>
                            <ColumnDefinition/><ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ArtNetNet, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="2" Text="{Binding ArtNetSubNet, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="4" Text="{Binding ArtNetUniverse, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <TextBlock Text="{Binding UniverseDisplay, StringFormat=Univers cible : {0}}"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10"
                    IsEnabled="{Binding IsBridgeMode}">
                <StackPanel>
                    <TextBlock Text="Sortie DMX" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Label Content="Type d'interface"/>
                    <ComboBox ItemsSource="{Binding OutputTypes}" SelectedItem="{Binding SelectedOutputType}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding OutputDevices}" SelectedItem="{Binding SelectedOutputDevice}" Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Détecter" Command="{Binding RefreshOutputDevicesCommand}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding OutputInfo}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="Mode analyse" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding MonitorSummary}" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,10">
            <UniformGrid Rows="2" Columns="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding ArtNetActive, Converter={StaticResource StatusBrushConverter}}"/>
                    <TextBlock Text="Art-Net" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,4">
                    <Label Content="FPS Art-Net"/>
                    <TextBlock Text="{Binding ArtNetFps, StringFormat={}{0:F1}}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,4">
                    <Label Content="FPS DMX"/>
                    <TextBlock Text="{Binding DmxFps, StringFormat={}{0:F1}}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,4">
                    <Label Content="Dernier paquet"/>
                    <TextBlock Text="{Binding LastPacketMs, StringFormat={}{0:F0} ms}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,4">
                    <Label Content="Source"/>
                    <TextBlock Text="{Binding MonitorSource}" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <Label Content="Paquets reçus"/>
                    <TextBlock Text="{Binding PacketsReceived, StringFormat=N0}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <Label Content="Paquets envoyés"/>
                    <TextBlock Text="{Binding PacketsSent, StringFormat=N0}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <Label Content="Séq. perdues"/>
                    <TextBlock Text="{Binding LostSequences}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Margin="0,0,8,0">
                    <Label Content="Hors ordre"/>
                    <TextBlock Text="{Binding OutOfOrderPackets}" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <Ellipse Width="10" Height="10" Margin="0,10,8,0"
                             Fill="{Binding DmxOutputConnected, Converter={StaticResource StatusBrushConverter}}"/>
                    <StackPanel>
                        <Label Content="Sortie DMX"/>
                        <TextBlock Text="{Binding DmxOutputConnected, Converter={StaticResource OutputStateConverter}}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Grid.Column="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Monitoring 512 canaux" FontWeight="SemiBold" Margin="4,4,4,8"/>
                <controls:DmxChannelMonitor x:Name="ChannelMonitor"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Grid.Column="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                Padding="8" Margin="0,10,0,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="4,4,4,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Journal" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <ComboBox Width="100" SelectedItem="{Binding MinimumLogLevel}">
                            <contracts:LogLevel>Trace</contracts:LogLevel>
                            <contracts:LogLevel>Debug</contracts:LogLevel>
                            <contracts:LogLevel>Info</contracts:LogLevel>
                            <contracts:LogLevel>Warning</contracts:LogLevel>
                            <contracts:LogLevel>Error</contracts:LogLevel>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Exporter" Command="{Binding ExportLogsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Effacer" Command="{Binding ClearLogsCommand}"/>
                    </StackPanel>
                </DockPanel>
                <ListBox ItemsSource="{Binding LogEntries}" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelBrushConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="OpenDMXBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OpenDMXBridge.Controls"
        xmlns:conv="clr-namespace:OpenDMXBridge.Converters"
        Title="OpenDMX Bridge"
        Height="820"
        Width="1180"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="StatusBrushConverter"/>
        <conv:LogLevelToBrushConverter x:Key="LogLevelBrushConverter"/>
        <conv:BridgeToggleTextConverter x:Key="BridgeToggleTextConverter"/>
        <conv:FtdiStateConverter x:Key="FtdiStateConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14,10"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OpenDMX Bridge" FontSize="18" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleBridgeCommand}"
                        Content="{Binding IsBridgeRunning, Converter={StaticResource BridgeToggleTextConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Left panel -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.RowSpan="2">
            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Réseau" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Label Content="Carte réseau"/>
                    <ComboBox ItemsSource="{Binding NetworkAdapters}"
                              SelectedItem="{Binding SelectedAdapter}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,8"/>
                    <Button Content="Actualiser" Command="{Binding RefreshAdaptersCommand}" Margin="0,0,0,12"/>

                    <Label Content="Univers Art-Net (Net.SubNet.Universe)"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ArtNetNet, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="2" Text="{Binding ArtNetSubNet, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox Grid.Column="4" Text="{Binding ArtNetUniverse, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                    <TextBlock Text="{Binding UniverseDisplay, StringFormat=Univers cible : {0}}"
                               Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Interface FTDI" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding FtdiDevices}"
                              SelectedItem="{Binding SelectedFtdiDevice}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Description}"/>
                                    <Run Text=" — " Foreground="{StaticResource MutedBrush}"/>
                                    <Run Text="{Binding SerialNumber}" Foreground="{StaticResource MutedBrush}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Détecter FTDI" Command="{Binding RefreshFtdiDevicesCommand}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding FtdiInfo}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Stats bar -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,8"
                Margin="0,0,0,10">
            <UniformGrid Rows="1" Columns="6">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                             Fill="{Binding ArtNetActive, Converter={StaticResource StatusBrushConverter}}"/>
                    <TextBlock Text="Art-Net" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <Label Content="FPS DMX"/>
                    <TextBlock Text="{Binding DmxFps, StringFormat={}{0:F1}}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <Label Content="Paquets reçus"/>
                    <TextBlock Text="{Binding PacketsReceived}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <Label Content="Paquets envoyés"/>
                    <TextBlock Text="{Binding PacketsSent}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel>
                    <Label Content="Paquets invalides"/>
                    <TextBlock Text="{Binding InvalidPackets}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,10,8,0"
                             Fill="{Binding FtdiConnected, Converter={StaticResource StatusBrushConverter}}"/>
                    <StackPanel>
                        <Label Content="FTDI"/>
                        <TextBlock Text="{Binding FtdiConnected, Converter={StaticResource FtdiStateConverter}, FallbackValue=Déconnecté}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Channel monitor -->
        <Border Grid.Row="2" Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Monitoring 512 canaux" FontWeight="SemiBold" Margin="4,4,4,8"/>
                <controls:DmxChannelMonitor x:Name="ChannelMonitor"/>
            </DockPanel>
        </Border>

        <!-- Logs -->
        <Border Grid.Row="3" Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,10,0,0">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="4,4,4,8">
                    <TextBlock Text="Journal" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="Effacer" Command="{Binding ClearLogsCommand}"/>
                </DockPanel>
                <ListBox ItemsSource="{Binding LogEntries}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelBrushConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>

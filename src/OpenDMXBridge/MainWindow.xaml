<Window x:Class="OpenDMXBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:OpenDMXBridge.Controls"
        xmlns:conv="clr-namespace:OpenDMXBridge.Converters"
        Title="OpenDMX Bridge"
        Height="780"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        FontFamily="Segoe UI"
        FontSize="12"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="StatusBrushConverter"/>
        <conv:LogLevelToBrushConverter x:Key="LogLevelBrushConverter"/>
        <conv:BridgeToggleTextConverter x:Key="BridgeToggleTextConverter"/>
        <conv:FtdiStateConverter x:Key="OutputStateConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <DockPanel Margin="10">
        <!-- Alerte FTDI -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WarnBgBrush}"
                BorderBrush="{StaticResource WarnBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,8"
                Margin="0,0,0,8"
                Visibility="{Binding ShowFtdiWarning, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="{Binding FtdiDriverMessage}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource WarnTextBrush}"/>
        </Border>

        <!-- Barre titre -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OpenDMX Bridge" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusText}" Margin="12,0,0,0" Foreground="#666" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Command="{Binding ToggleBridgeCommand}"
                        Content="{Binding IsBridgeRunning, Converter={StaticResource BridgeToggleTextConverter}}"/>
            </DockPanel>
        </Border>

        <!-- Journal -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                CornerRadius="4" Height="180" Margin="0,8,0,0">
            <DockPanel Margin="8">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="Journal" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <ComboBox Width="110" Margin="0,0,8,0"
                                  ItemsSource="{Binding LogLevelOptions}"
                                  SelectedItem="{Binding SelectedLogLevel}"
                                  DisplayMemberPath="Label"/>
                        <Button Content="Exporter" Command="{Binding ExportLogsCommand}" Margin="0,0,6,0" Padding="10,4"/>
                        <Button Content="Effacer" Command="{Binding ClearLogsCommand}" Padding="10,4"/>
                    </StackPanel>
                </DockPanel>
                <ListBox ItemsSource="{Binding LogEntries}" BorderThickness="1" BorderBrush="#E0E0E0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Foreground="{Binding Level, Converter={StaticResource LogLevelBrushConverter}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Corps -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panneau gauche -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="Mode" Style="{StaticResource SectionGroup}">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding OperationModeOptions}"
                                      SelectedItem="{Binding SelectedOperationMode}"
                                      DisplayMemberPath="Label"/>
                            <TextBlock Margin="0,6,0,0" Foreground="#666" FontSize="11" TextWrapping="Wrap"
                                       Text="Monitor : analyse Art-Net sans sortie DMX."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Réseau" Style="{StaticResource SectionGroup}">
                        <StackPanel>
                            <TextBlock Text="Carte réseau" Margin="0,0,0,4" Foreground="#444"/>
                            <ComboBox ItemsSource="{Binding NetworkAdapters}"
                                      SelectedItem="{Binding SelectedAdapter}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,0,0,6"/>
                            <Button Content="Actualiser les cartes" Command="{Binding RefreshAdaptersCommand}"
                                    HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,10"/>
                            <TextBlock Text="Univers Art-Net (Net · SubNet · Universe)" Margin="0,0,0,4" Foreground="#444"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/><ColumnDefinition Width="6"/>
                                    <ColumnDefinition/><ColumnDefinition Width="6"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ArtNetNet, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Text="{Binding ArtNetSubNet, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="4" Text="{Binding ArtNetUniverse, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Text="{Binding UniverseDisplay, StringFormat=Univers cible : {0}}" Foreground="#666"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Sortie DMX" Style="{StaticResource SectionGroup}"
                              IsEnabled="{Binding IsBridgeMode}">
                        <StackPanel>
                            <TextBlock Text="Type d'interface" Margin="0,0,0,4" Foreground="#444"/>
                            <ComboBox ItemsSource="{Binding OutputTypes}"
                                      SelectedItem="{Binding SelectedOutputType}"
                                      Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding OutputDevices}"
                                      SelectedItem="{Binding SelectedOutputDevice}"
                                      DisplayMemberPath="Description"
                                      Margin="0,0,0,6"/>
                            <Button Content="Détecter les interfaces" Command="{Binding RefreshOutputDevicesCommand}"
                                    HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding OutputInfo}" TextWrapping="Wrap" Foreground="#666"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Analyse" Style="{StaticResource SectionGroup}">
                        <TextBlock Text="{Binding MonitorSummary}" FontFamily="Consolas" FontSize="11"
                                   Foreground="#444" TextWrapping="Wrap"/>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Panneau droit -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                        CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,8">
                            <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center"
                                     Fill="{Binding ArtNetActive, Converter={StaticResource StatusBrushConverter}}"/>
                            <TextBlock Text="Art-Net" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                            <TextBlock Text="FPS Art-Net" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding ArtNetFps, StringFormat={}{0:F1}}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
                            <TextBlock Text="FPS DMX" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding DmxFps, StringFormat={}{0:F1}}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,8,8">
                            <TextBlock Text="Dernier paquet" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding LastPacketDisplay}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,8">
                            <TextBlock Text="Source" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding MonitorSource}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Paquets reçus" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding PacketsReceived, StringFormat=N0}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Paquets envoyés" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding PacketsSent, StringFormat=N0}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Séq. perdues" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding LostSequences}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Text="Hors ordre" FontSize="11" Foreground="#666"/>
                            <TextBlock Text="{Binding OutOfOrderPackets}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,4,6,0"
                                     Fill="{Binding DmxOutputConnected, Converter={StaticResource StatusBrushConverter}}"/>
                            <StackPanel>
                                <TextBlock Text="Sortie DMX" FontSize="11" Foreground="#666"/>
                                <TextBlock Text="{Binding DmxOutputConnected, Converter={StaticResource OutputStateConverter}}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="512 canaux DMX" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <controls:DmxChannelMonitor x:Name="ChannelMonitor" MinHeight="200"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
